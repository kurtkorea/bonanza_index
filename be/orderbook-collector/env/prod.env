PORT=6001

#시세설정
DEPTH=15
TICK_MS=1000

SYMBOL=KRW-BTC

#ZMQ 설정
ZMQ_PUSH_HOST=tcp://127.0.0.1:5557
ZMQ_SUB_COMMAND_HOST=tcp://127.0.0.1:7757
# ZMQ 전송 timeout (밀리초, 기본값: 2000ms)
ZMQ_SEND_TIMEOUT=2000

#QUEUE 사이즈
PUSH_QUEUE_SIZE=100000
PUB_QUEUE_SIZE=100000

#raw데이터 저장하나??
IS_RAW_DATA=true

#DB 설정
QDB_HOST=localhost
QDB_PORT=8812
QDB_DB=qdb
QDB_USER=admin
QDB_PASS=quest
QDB_LOG=false

#QuestDB ILP 설정
QDB_ILP_HOST=localhost
QDB_ILP_PORT=9009

#MYSQL설정
DB_DIALECT=mysql
DB_HOST=mariadb-service
DB_PORT=30306
DB_SCHEME=dayfin
DB_USERNAME=bonanza
DB_PASSWORD=56tyghbn

REDIS_HOST=10.40.100.21
REDIS_PORT=6379
REDIS_STORE=BONANZA-INDEX

#Telegram 서비스 설정
TELEGRAM_SERVICE_URL=http://127.0.0.1:3109/v1/telegram

WS_QUEUE_MONITOR_INTERVAL=600000
WS_QUEUE_MAX_SIZE=5000

COLLECTOR_ROLE=primary

PROCESS_ID=collector-process

# 리더 선출 활성화 (기본값: true)
ENABLE_LEADER_ELECTION=true

# 리더십 키 (기본값: orderbook-collector:leader)
LEADER_KEY=orderbook-collector:leader

# 리더십 TTL (초, 기본값: 10초)
LEADER_LEASE_TIME=10

# 리더십 갱신 주기 (밀리초, 기본값: TTL의 절반)
LEADER_RENEW_INTERVAL=5000

# 리더십 재획득 시도 주기 (밀리초, 기본값: 2000)
LEADER_RETRY_INTERVAL=2000

