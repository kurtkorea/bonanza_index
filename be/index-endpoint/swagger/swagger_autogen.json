{
  "swagger": "2.0",
  "openapi": false,
  "info": {
    "title": "index-calculator",
    "version": "1.0.0",
    "description": ""
  },
  "host": "localhost:3009",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "paths": {
    "/health": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "성공"
          }
        }
      }
    },
    "/v1/index_history/": {
      "get": {
        "tags": [
          "Index History"
        ],
        "description": "FKBRTI 지수 히스토리 조회 (기본 데이터)",
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "type": "string"
          },
          {
            "name": "from_date",
            "in": "query",
            "type": "datetime",
            "description": "검색시작시간 (예: 2025-09-01T00:00:00Z)"
          },
          {
            "name": "to_date",
            "in": "query",
            "type": "datetime",
            "description": "검색마지막시간 (예: 2025-09-30T23:59:59Z)"
          },
          {
            "name": "page",
            "in": "query",
            "type": "integer",
            "description": "페이지 번호 (기본값: 1)"
          },
          {
            "name": "size",
            "in": "query",
            "type": "integer",
            "description": "페이지 크기 (기본값: 100)"
          },
          {
            "name": "order",
            "in": "query",
            "type": "string",
            "description": "정렬 순서 - asc 또는 desc (기본값: desc)"
          }
        ],
        "responses": {
          "200": {
            "description": "성공"
          },
          "400": {
            "description": "잘못된 요청"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/index_calc/": {
      "get": {
        "tags": [
          "Index Calculation"
        ],
        "description": "FKBRTI 지수 계산 (5초, 10초 이동평균 포함)",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "type": "string"
          },
          {
            "name": "sort",
            "in": "query",
            "type": "string"
          },
          {
            "name": "from_date",
            "in": "query",
            "type": "datetime",
            "description": "검색시작시간 (예: 2025-09-01T00:00:00Z)"
          },
          {
            "name": "to_date",
            "in": "query",
            "type": "datetime",
            "description": "검색마지막시간 (예: 2025-09-30T23:59:59Z)"
          },
          {
            "name": "page",
            "in": "query",
            "type": "integer",
            "description": "페이지 번호 (기본값: 1)"
          },
          {
            "name": "size",
            "in": "query",
            "type": "integer",
            "description": "페이지 크기 (기본값: 100)"
          },
          {
            "name": "order",
            "in": "query",
            "type": "string",
            "description": "정렬 순서 - asc 또는 desc (기본값: desc)"
          }
        ],
        "responses": {
          "200": {
            "description": "성공"
          },
          "400": {
            "description": "잘못된 요청"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/index_calc/stats": {
      "get": {
        "tags": [
          "Index Calculation"
        ],
        "description": "FKBRTI 통계 조회 (기간별 DIFF 및 RATIO 통계) - 1D, 1W, 1M, 1Y (tb_fkbrti_summary 테이블에서 조회)",
        "parameters": [
          {
            "name": "symbol",
            "in": "query",
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "성공 시 통계 데이터 반환"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/file_download/": {
      "get": {
        "tags": [
          "Index History"
        ],
        "description": "FKBRTI 지수 히스토리 파일 다운로드",
        "parameters": [
          {
            "name": "from_date",
            "in": "query",
            "type": "string",
            "description": "검색시작시간 (예: 2025-09-01)"
          },
          {
            "name": "to_date",
            "in": "query",
            "type": "string",
            "description": "검색마지막시간 (예: 2025-09-30)"
          }
        ],
        "responses": {
          "400": {
            "description": "잘못된 요청"
          },
          "404": {
            "description": "찾을 수 없음"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          },
          "500": {
            "description": "내부 서버 오류"
          }
        }
      }
    },
    "/v1/command/": {
      "get": {
        "tags": [
          "Index History"
        ],
        "description": "명령어 요청",
        "parameters": [
          {
            "name": "process_id",
            "in": "query",
            "type": "string",
            "description": "프로세스 ID"
          },
          {
            "name": "command",
            "in": "query",
            "type": "string",
            "description": "명령어"
          }
        ],
        "responses": {
          "200": {
            "description": "성공"
          },
          "400": {
            "description": "잘못된 요청"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/master/": {
      "get": {
        "tags": [
          "Index History"
        ],
        "description": "마스터 데이터 요청",
        "responses": {
          "200": {
            "description": "성공"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/minio_access/list": {
      "get": {
        "tags": [
          "MinIO Access"
        ],
        "description": "MinIO 버킷 파일 리스트 조회 (폴더 구조 지원)",
        "parameters": [
          {
            "name": "prefix",
            "in": "query",
            "type": "string",
            "description": "파일 경로 prefix (예: orderbook/)"
          },
          {
            "name": "maxKeys",
            "in": "query",
            "type": "integer",
            "description": "최대 반환 개수 (기본: 1000)"
          },
          {
            "name": "continuationToken",
            "in": "query",
            "type": "string",
            "description": "페이징용 continuation token"
          },
          {
            "name": "delimiter",
            "in": "query",
            "type": "string",
            "description": "폴더 구분자 (기본: /)"
          }
        ],
        "responses": {
          "200": {
            "description": "성공"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/minio_access/": {
      "get": {
        "tags": [
          "MinIO Access"
        ],
        "description": "MinIO 버킷 파일 리스트 조회 (기본 엔드포인트)",
        "parameters": [
          {
            "name": "continuationToken",
            "in": "query",
            "type": "string"
          },
          {
            "name": "prefix",
            "in": "query",
            "type": "string",
            "description": "파일 경로 prefix (예: orderbook/)"
          },
          {
            "name": "maxKeys",
            "in": "query",
            "type": "integer",
            "description": "최대 반환 개수 (기본: 1000)"
          }
        ],
        "responses": {
          "200": {
            "description": "성공"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          }
        }
      }
    },
    "/v1/minio_access/download": {
      "get": {
        "tags": [
          "MinIO Access"
        ],
        "description": "MinIO 버킷 파일 다운로드",
        "produces": [
          null
        ],
        "parameters": [
          {
            "name": "key",
            "in": "query",
            "type": "string",
            "required": true,
            "description": "다운로드할 파일의 키 (예: orderbook/orderbook_20251126_KRW-BTC.csv.gz)"
          }
        ],
        "responses": {
          "400": {
            "description": "잘못된 요청"
          },
          "404": {
            "description": "찾을 수 없음"
          },
          "440": {
            "description": "각종 오류 - 상세 내용은 message 참조"
          },
          "500": {
            "description": "내부 서버 오류"
          }
        }
      }
    }
  }
}