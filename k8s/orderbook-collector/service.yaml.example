# 이 파일은 예제입니다.
# 다중 인스턴스 배포를 위해서는 service-1.yaml과 service-2.yaml을 사용하세요.
# 단일 인스턴스 배포가 필요한 경우에만 이 파일을 service.yaml로 이름을 변경하여 사용하세요.

apiVersion: v1
kind: Service
metadata:
  name: orderbook-collector-service
  namespace: bonanza-index
  labels:
    app: orderbook-collector
spec:
  type: ClusterIP
  ports:
  - port: 6001
    targetPort: 6001
    protocol: TCP
    name: http
  - port: 6557
    targetPort: 6557
    protocol: TCP
    name: zmq-pub
  - port: 5557
    targetPort: 5557
    protocol: TCP
    name: zmq-push
  selector:
    app: orderbook-collector

