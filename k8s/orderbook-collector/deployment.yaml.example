# 이 파일은 예제입니다.
# 다중 인스턴스 배포를 위해서는 deployment-1.yaml과 deployment-2.yaml을 사용하세요.
# 단일 인스턴스 배포가 필요한 경우에만 이 파일을 deployment.yaml로 이름을 변경하여 사용하세요.

apiVersion: apps/v1
kind: Deployment
metadata:
  name: orderbook-collector
  namespace: bonanza-index
  labels:
    app: orderbook-collector
spec:
  replicas: 1
  selector:
    matchLabels:
      app: orderbook-collector
  template:
    metadata:
      labels:
        app: orderbook-collector
    spec:
      dnsPolicy: "ClusterFirst"
      containers:
      - name: orderbook-collector
        image: bonanza-index/orderbook-collector:latest
        imagePullPolicy: Never
        ports:
        - containerPort: 6001
          name: http
          protocol: TCP
        env:
        - name: PORT
          value: "6001"
        - name: DEPTH
          value: "15"
        - name: TICK_MS
          value: "1000"
        - name: SYMBOL
          value: "KRW-BTC"
        - name: ZMQ_PUSH_PORT
          value: "5557"
        - name: ZMQ_PUB_PORT
          value: "6557"
        - name: PUSH_QUEUE_SIZE
          value: "100000"
        - name: PUB_QUEUE_SIZE
          value: "100000"
        - name: IS_RAW_DATA
          value: "true"
        - name: TELEGRAM_SERVICE_URL
          value: "http://telegram-log-service:3109/v1/telegram"
        - name: WS_QUEUE_MAX_SIZE
          value: "5000"
        - name: WS_QUEUE_BATCH_SIZE
          value: "50"
        - name: WS_QUEUE_PROCESS_INTERVAL
          value: "20"
        - name: WS_QUEUE_MONITOR_INTERVAL
          value: "30000"
        - name: CPU_CORES
          value: "2"
        - name: NODE_OPTIONS
          value: "--no-warnings"
        - name: NODE_NO_WARNINGS
          value: "1"
        - name: PYTHONUNBUFFERED
          value: "1"
        # Process ID 설정 (단일 인스턴스용)
        - name: PROCESS_ID
          value: "orderbook-collector-process-single"
        envFrom:
        - configMapRef:
            name: bonanza-common-config
        - secretRef:
            name: bonanza-secrets
        resources:
          requests:
            memory: "128Mi"
            cpu: "60m"
          limits:
            memory: "256Mi"
            cpu: "200m"
        livenessProbe:
          httpGet:
            path: /health
            port: 6001
          initialDelaySeconds: 30
          periodSeconds: 10
          timeoutSeconds: 5
          failureThreshold: 3
        readinessProbe:
          httpGet:
            path: /health
            port: 6001
          initialDelaySeconds: 10
          periodSeconds: 5
          timeoutSeconds: 3
          failureThreshold: 3

